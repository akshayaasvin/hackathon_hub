# Public — safe to expose to the browser. From Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER add a NEXT_PUBLIC_ prefix to this or expose it to the client bundle.
# From Supabase Dashboard -> Project Settings -> API -> service_role key.
# Used by lib/supabase/admin.ts, imported only from app/api/** route handlers, to:
#   - create the auth account for an applicant only at admin-approval time
#   - insert users/profile rows before a session exists (registration, approval)
#   - ban a rejected applicant's account at the auth layer
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. From https://resend.com/api-keys after creating a Resend account.
# Used by lib/email.ts for every transactional email (application received,
# approved-with-credentials, rejected, changes-requested).
RESEND_API_KEY=

# Server-only. The "from" address for the emails above, e.g.
# "HackathonHub <onboarding@resend.dev>" (works out of the box for testing;
# use a verified domain for production).
RESEND_FROM_EMAIL=

# Server-only. Signing secret from your Razorpay Dashboard -> Webhooks, for
# the webhook at app/api/webhooks/razorpay. Optional — payment confirmation
# also works via the participant's manual "Mark Payment Complete" step
# without this configured.
RAZORPAY_WEBHOOK_SECRET=

# Server-only. API Key ID/Secret from Razorpay Dashboard -> Settings -> API Keys.
# Used by lib/razorpay.ts to create real Orders (app/api/registrations/[id]/create-order).
# Required for the "Pay Now" flow to work at all — without these, create-order
# returns a 501 telling the student payments aren't configured yet.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public — safe to expose to the browser. Used as the emailRedirectTo base for
# Supabase Auth confirmation emails (app/api/auth/register). Falls back to the
# request's own origin if unset, so this is optional in most deployments.
NEXT_PUBLIC_SITE_URL=

# Public — safe to expose to the browser. Full international format (country
# code + number, no + or spaces, e.g. 918553451935). Used by the floating
# WhatsApp support button (components/WhatsAppButton.tsx) rendered site-wide.
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=
